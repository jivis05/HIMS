# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your real values. Never commit .env!

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/hims

# JWT settings
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_EXPIRES_IN=7d

# Server port (default: 5000)
PORT=5000

# CORS – frontend origin (default: http://localhost:5173)
CLIENT_URL=http://localhost:5173

# Logging level (error | warn | info | debug)
LOG_LEVEL=info

# ─── Seeding & Testing ────────────────────────────────────────────────────────
# Default password for seeded users and automated tests
SEED_PASSWORD=your_secure_test_password_here
